@{
    var (bgVar, colorVar, ring, icon) = Status?.ToLower() switch
    {
        "completed" or "created" or "synced" => ("var(--success-bg)", "var(--success)", "#6ee7b7", "✓"),
        "pending"    => ("var(--warning-bg)", "var(--warning)", "#fcd34d", "⏳"),
        "processing" => ("#dbeafe",           "#2563eb",        "#93c5fd", "↻"),
        "failed"     => ("var(--error-bg)",   "var(--error)",   "#fca5a5", "✕"),
        _            => ("#f1f5f9",           "#64748b",        "#cbd5e1", "·")
    };
}
<span style="background:@bgVar; color:@colorVar; box-shadow:0 0 0 1px @ring inset;"
      class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium">
    <span class="text-[10px]">@icon</span>@Status
</span>

@code {
    [Parameter] public string? Status { get; set; }
}
