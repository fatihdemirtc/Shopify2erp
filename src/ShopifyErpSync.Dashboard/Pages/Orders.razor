@page "/orders"
@inject IDbContextFactory<AppDbContext> DbFactory

<Microsoft.AspNetCore.Components.Sections.SectionContent SectionName="page-title">Orders</Microsoft.AspNetCore.Components.Sections.SectionContent>

<div class="bg-white rounded-lg border border-slate-200 shadow-sm">
    <div class="px-6 py-4 border-b border-slate-100 flex justify-between items-center">
        <h2 class="font-semibold text-slate-800">All Orders</h2>
        <span class="text-sm text-slate-500">@_total total</span>
    </div>

    <table class="w-full text-sm">
        <thead class="bg-slate-50">
            <tr>
                <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Order #</th>
                <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Customer</th>
                <th class="text-right px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Subtotal</th>
                <th class="text-right px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Tax</th>
                <th class="text-right px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Total</th>
                <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Status</th>
                <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Created</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var (order, i) in _orders.Select((o, i) => (o, i)))
            {
                <tr class="@(i % 2 == 0 ? "bg-white" : "bg-slate-50") hover:bg-slate-100 transition-colors">
                    <td class="px-6 py-3 font-medium text-slate-800">#@order.OrderNumber</td>
                    <td class="px-6 py-3 text-slate-600">@order.Customer?.Name</td>
                    <td class="px-6 py-3 text-right text-slate-700">$@order.Subtotal.ToString("N2")</td>
                    <td class="px-6 py-3 text-right text-slate-500">$@order.Vat.ToString("N2")</td>
                    <td class="px-6 py-3 text-right font-semibold text-slate-800">$@order.Total.ToString("N2")</td>
                    <td class="px-6 py-3"><StatusBadge Status="@order.Status" /></td>
                    <td class="px-6 py-3 text-slate-500 text-xs">@order.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                </tr>
            }
            @if (!_orders.Any())
            {
                <tr><td colspan="7" class="px-6 py-10 text-center text-slate-400">No orders yet</td></tr>
            }
        </tbody>
    </table>

    <!-- Pagination -->
    @if (_totalPages > 1)
    {
        <div class="px-6 py-4 border-t border-slate-100 flex justify-between items-center">
            <button class="px-3 py-1.5 text-sm border border-slate-200 rounded hover:bg-slate-50 disabled:opacity-40"
                    disabled="@(_page <= 1)" @onclick="PrevPage">Previous</button>
            <span class="text-sm text-slate-500">Page @_page of @_totalPages</span>
            <button class="px-3 py-1.5 text-sm border border-slate-200 rounded hover:bg-slate-50 disabled:opacity-40"
                    disabled="@(_page >= _totalPages)" @onclick="NextPage">Next</button>
        </div>
    }
</div>

@code {
    private List<Order> _orders = new();
    private int _page = 1, _total, _totalPages;
    private const int PageSize = 25;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _total = await db.Orders.CountAsync();
        _totalPages = (int)Math.Ceiling(_total / (double)PageSize);
        _orders = await db.Orders
            .Include(o => o.Customer)
            .OrderByDescending(o => o.CreatedAt)
            .Skip((_page - 1) * PageSize)
            .Take(PageSize)
            .ToListAsync();
    }

    private async Task PrevPage() { _page--; await LoadAsync(); }
    private async Task NextPage() { _page++; await LoadAsync(); }
}
