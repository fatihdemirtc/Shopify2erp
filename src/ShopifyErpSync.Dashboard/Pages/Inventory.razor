@page "/inventory"
@inject IDbContextFactory<AppDbContext> DbFactory

<Microsoft.AspNetCore.Components.Sections.SectionContent SectionName="page-title">Inventory</Microsoft.AspNetCore.Components.Sections.SectionContent>

<div class="bg-white rounded-lg border border-slate-200 shadow-sm">
    <div class="px-6 py-4 border-b border-slate-100">
        <h2 class="font-semibold text-slate-800">Products &amp; Stock Levels</h2>
    </div>

    <table class="w-full text-sm">
        <thead class="bg-slate-50">
            <tr>
                <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">SKU</th>
                <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Name</th>
                <th class="text-right px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Stock</th>
                <th class="text-right px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Price</th>
                <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Level</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var (product, i) in _products.Select((p, i) => (p, i)))
            {
                <tr class="@(i % 2 == 0 ? "bg-white" : "bg-slate-50") hover:bg-slate-100 transition-colors">
                    <td class="px-6 py-3 font-mono text-xs text-slate-600">@product.Sku</td>
                    <td class="px-6 py-3 font-medium text-slate-800">@product.Name</td>
                    <td class="px-6 py-3 text-right font-semibold @(product.StockQuantity <= 5 ? "text-red-600" : product.StockQuantity <= 15 ? "text-amber-600" : "text-emerald-600")">
                        @product.StockQuantity
                    </td>
                    <td class="px-6 py-3 text-right text-slate-700">$@product.Price.ToString("N2")</td>
                    <td class="px-6 py-3">
                        @if (product.StockQuantity <= 5)
                        {
                            <span class="px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-700">Low</span>
                        }
                        else if (product.StockQuantity <= 15)
                        {
                            <span class="px-2 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-700">Medium</span>
                        }
                        else
                        {
                            <span class="px-2 py-0.5 rounded text-xs font-medium bg-emerald-100 text-emerald-700">In Stock</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private List<Product> _products = new();

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _products = await db.Products.OrderBy(p => p.Name).ToListAsync();
    }
}
