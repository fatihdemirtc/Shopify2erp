@page "/outbox"
@inject IDbContextFactory<AppDbContext> DbFactory

<Microsoft.AspNetCore.Components.Sections.SectionContent SectionName="page-title">Outbox Queue</Microsoft.AspNetCore.Components.Sections.SectionContent>

<div class="space-y-4">
    <!-- Filter -->
    <div class="flex gap-2">
        @foreach (var s in new[] { "all", "pending", "processing", "completed", "failed" })
        {
            <button class="px-3 py-1.5 rounded text-sm border @(_filter == s ? "bg-slate-800 text-white border-slate-800" : "bg-white border-slate-200 text-slate-600 hover:bg-slate-50")"
                    @onclick="() => SetFilter(s)">
                @(s == "all" ? "All" : char.ToUpper(s[0]) + s[1..])
            </button>
        }
    </div>

    <div class="bg-white rounded-lg border border-slate-200 shadow-sm">
        <table class="w-full text-sm">
            <thead class="bg-slate-50">
                <tr>
                    <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">ID</th>
                    <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Type</th>
                    <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Status</th>
                    <th class="text-right px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Attempts</th>
                    <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Next Retry</th>
                    <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Error</th>
                    <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Created</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var (msg, i) in _messages.Select((m, i) => (m, i)))
                {
                    <tr class="@(i % 2 == 0 ? "bg-white" : "bg-slate-50") hover:bg-slate-100 transition-colors">
                        <td class="px-5 py-3 font-mono text-xs text-slate-500">@msg.Id.ToString()[..8]…</td>
                        <td class="px-5 py-3 text-slate-700">@msg.MessageType</td>
                        <td class="px-5 py-3"><StatusBadge Status="@msg.Status" /></td>
                        <td class="px-5 py-3 text-right text-slate-600">@msg.AttemptCount</td>
                        <td class="px-5 py-3 text-slate-500 text-xs">@(msg.NextRetryAt.HasValue ? msg.NextRetryAt.Value.ToLocalTime().ToString("HH:mm:ss") : "—")</td>
                        <td class="px-5 py-3 text-red-600 text-xs max-w-xs truncate">@(msg.ErrorMessage ?? "—")</td>
                        <td class="px-5 py-3 text-slate-500 text-xs">@msg.CreatedAt.ToLocalTime().ToString("HH:mm:ss")</td>
                    </tr>
                }
                @if (!_messages.Any())
                {
                    <tr><td colspan="7" class="px-5 py-10 text-center text-slate-400">Queue is empty</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<OutboxMessage> _messages = new();
    private string _filter = "all";

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task SetFilter(string filter)
    {
        _filter = filter;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var query = db.OutboxMessages.AsQueryable();
        if (_filter != "all")
            query = query.Where(m => m.Status == _filter);
        _messages = await query.OrderByDescending(m => m.CreatedAt).Take(100).ToListAsync();
    }
}
