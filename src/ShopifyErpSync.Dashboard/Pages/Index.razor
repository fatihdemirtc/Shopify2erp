@page "/"
@inject IDbContextFactory<AppDbContext> DbFactory
@implements IDisposable

<Microsoft.AspNetCore.Components.Sections.SectionContent SectionName="page-title">Dashboard</Microsoft.AspNetCore.Components.Sections.SectionContent>

<div class="space-y-6">

    @if (_loading)
    {
        <!-- Skeleton: metric cards -->
        <div class="grid grid-cols-4 gap-4">
            @for (int i = 0; i < 4; i++)
            {
                <div class="bg-white rounded-xl shadow-card p-6 animate-pulse">
                    <div class="h-3 bg-slate-200 rounded w-28 mb-3"></div>
                    <div class="h-8 bg-slate-200 rounded w-20"></div>
                </div>
            }
        </div>
        <!-- Skeleton: table + outbox -->
        <div class="grid grid-cols-3 gap-4">
            <div class="col-span-2 bg-white rounded-xl shadow-card p-6 animate-pulse space-y-3">
                <div class="h-4 bg-slate-200 rounded w-32"></div>
                @for (int i = 0; i < 5; i++)
                {
                    <div class="h-10 bg-slate-100 rounded"></div>
                }
            </div>
            <div class="bg-white rounded-xl shadow-card p-6 animate-pulse space-y-4">
                <div class="h-4 bg-slate-200 rounded w-28"></div>
                @for (int i = 0; i < 4; i++)
                {
                    <div class="flex justify-between">
                        <div class="h-3 bg-slate-200 rounded w-20"></div>
                        <div class="h-3 bg-slate-200 rounded w-8"></div>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <!-- Metric cards -->
        <div class="grid grid-cols-4 gap-4">
            <div class="bg-white rounded-xl shadow-card p-6">
                <p class="text-xs font-medium text-slate-500 uppercase tracking-wider mb-1">Orders Today</p>
                <p class="text-3xl font-bold text-slate-900">@_ordersToday.ToString("N0")</p>
            </div>
            <div class="bg-white rounded-xl shadow-card p-6">
                <p class="text-xs font-medium text-slate-500 uppercase tracking-wider mb-1">Revenue Today</p>
                <p class="text-3xl font-bold text-slate-900">$@_revenueToday.ToString("N2")</p>
            </div>
            <div class="bg-white rounded-xl shadow-card p-6">
                <p class="text-xs font-medium text-slate-500 uppercase tracking-wider mb-1">Sync Success (24h)</p>
                <p class="text-3xl font-bold @(_successRate >= 95 ? "text-emerald-600" : "text-amber-600")">@_successRate.ToString("F0")%</p>
            </div>
            <div class="bg-white rounded-xl shadow-card p-6">
                <p class="text-xs font-medium text-slate-500 uppercase tracking-wider mb-1">Pending in Queue</p>
                <p class="text-3xl font-bold @(_pendingCount > 0 ? "text-amber-600" : "text-slate-900")">@_pendingCount.ToString("N0")</p>
            </div>
        </div>

        <div class="grid grid-cols-3 gap-4">
            <!-- Recent orders -->
            <div class="col-span-2 bg-white rounded-xl shadow-card overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
                    <h2 class="font-semibold text-slate-800">Recent Orders</h2>
                    <span class="text-xs text-slate-400">Last updated: @_lastRefreshed.ToLocalTime().ToString("HH:mm:ss")</span>
                </div>
                <table class="w-full text-sm">
                    <thead class="bg-slate-50">
                        <tr>
                            <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Order</th>
                            <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Customer</th>
                            <th class="text-right px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Total</th>
                            <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Status</th>
                            <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Time</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var (order, i) in _recentOrders.Select((o, i) => (o, i)))
                        {
                            <tr class="@(i % 2 == 0 ? "bg-white" : "bg-slate-50/50") hover:bg-indigo-50/40 transition-colors">
                                <td class="px-6 py-3 font-medium text-slate-800">#@order.OrderNumber</td>
                                <td class="px-6 py-3 text-slate-600">@order.Customer?.Name</td>
                                <td class="px-6 py-3 text-right font-medium">$@order.Total.ToString("N2")</td>
                                <td class="px-6 py-3"><StatusBadge Status="@order.Status" /></td>
                                <td class="px-6 py-3 text-slate-500 text-xs">@order.CreatedAt.ToLocalTime().ToString("HH:mm:ss")</td>
                            </tr>
                        }
                        @if (!_recentOrders.Any())
                        {
                            <tr><td colspan="5" class="px-6 py-10 text-center text-slate-400 text-sm">No orders yet</td></tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Outbox health -->
            <div class="bg-white rounded-xl shadow-card">
                <div class="px-6 py-4 border-b border-slate-100">
                    <h2 class="font-semibold text-slate-800">Outbox Health</h2>
                </div>
                <div class="p-6 space-y-4">
                    <div class="flex justify-between items-center">
                        <span class="text-sm text-slate-600">Pending</span>
                        <span class="text-sm font-semibold text-amber-600">@_pendingCount.ToString("N0")</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-sm text-slate-600">Processing</span>
                        <span class="text-sm font-semibold text-blue-600">@_processingCount.ToString("N0")</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-sm text-slate-600">Completed</span>
                        <span class="text-sm font-semibold text-emerald-600">@_completedCount.ToString("N0")</span>
                    </div>
                    <div class="flex justify-between items-center border-t border-slate-100 pt-4">
                        <span class="text-sm text-slate-600">Failed</span>
                        <span class="text-sm font-semibold @(_failedCount > 0 ? "text-red-600" : "text-slate-400")">@_failedCount.ToString("N0")</span>
                    </div>
                </div>
                <div class="px-6 pb-4">
                    <p class="text-xs text-slate-400 text-center">Auto-refreshes every 5s</p>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Order> _recentOrders = new();
    private int _ordersToday, _pendingCount, _processingCount, _completedCount, _failedCount;
    private decimal _revenueToday;
    private double _successRate;
    private bool _loading = true;
    private DateTime _lastRefreshed = DateTime.UtcNow;
    private System.Threading.Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
        _loading = false;
        _timer = new System.Threading.Timer(async _ =>
        {
            await LoadDataAsync();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));
    }

    private async Task LoadDataAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var today = DateTime.UtcNow.Date;

            _recentOrders = await db.Orders
                .Include(o => o.Customer)
                .OrderByDescending(o => o.CreatedAt)
                .Take(20)
                .ToListAsync();

            _ordersToday    = await db.Orders.CountAsync(o => o.CreatedAt >= today);
            _revenueToday   = await db.Orders.Where(o => o.CreatedAt >= today).SumAsync(o => (decimal?)o.Total) ?? 0;
            _pendingCount   = await db.OutboxMessages.CountAsync(m => m.Status == "pending");
            _processingCount= await db.OutboxMessages.CountAsync(m => m.Status == "processing");
            _completedCount = await db.OutboxMessages.CountAsync(m => m.Status == "completed");
            _failedCount    = await db.OutboxMessages.CountAsync(m => m.Status == "failed");

            var since    = DateTime.UtcNow.AddHours(-24);
            var total24h = await db.AuditLog.CountAsync(a => (a.Action == "OrderSynced" || a.Action == "OrderSyncFailed") && a.CreatedAt >= since);
            var success24h = await db.AuditLog.CountAsync(a => a.Action == "OrderSynced" && a.CreatedAt >= since);
            _successRate = total24h > 0 ? (double)success24h / total24h * 100 : 100;

            _lastRefreshed = DateTime.UtcNow;
        }
        catch { }
    }

    public void Dispose() => _timer?.Dispose();
}
