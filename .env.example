SHOPIFY_WEBHOOK_SECRET=your_shared_secret_from_shopify_partner
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ERP Adapter: Sql | RestApi | Odoo
ERP_ADAPTER=Sql

# Odoo (required when ERP_ADAPTER=Odoo)
# host.docker.internal resolves to host machine from inside Docker (Windows/Mac Docker Desktop)
# On Linux Docker: use the actual host IP or join the Odoo container network
ODOO_BASE_URL=http://host.docker.internal:8069
ODOO_DB=odoo
ODOO_USER=admin
ODOO_API_KEY=your_odoo_api_key_here
ODOO_STOCK_LOCATION_ID=8
